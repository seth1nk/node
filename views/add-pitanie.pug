doctype html
html(lang="ru")
  head
    title Добавить продукт
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css")
    link(rel='stylesheet', href='/stylesheets/style.css')
  body
    div.app-container
      h1.page-title Добавить новый продукт
      form.form-container(action='/add-pitanie' method='POST' enctype='multipart/form-data')
        .input-group
            label(for="name") Название:
            input#name.form-input(type="text" name="name" required)
        .input-group
            label(for="vid") Вид:
            select#vid.form-input(name="vid" required)
              option(value="обезьяна") Обезьяна
              option(value="крыса") Крыса
              option(value="попугай") Попугай
              option(value="кошка") Кошка
              option(value="собака") Собака
              option(value="рыбки") Рыбки
              option(value="черепаха") Черепаха
              option(value="кролик") Кролик
              option(value="еж") Еж
              option(value="хомяк") Хомяк
        .input-group
            label(for="brand") Бренд:
            input#brand.form-input(type="text" name="brand" required)
        .input-group
            label(for="weight") Вес упаковки:
            input#weight.form-input(type="number" name="weight" step="0.01" required)
        .input-group
            label(for="description") Описание:
            textarea#description.form-input(name="description" rows="4")
        .input-group
            label(for="price") Цена:
            input#price.form-input(type="number" name="price" step="0.01" required)
        .input-group
            label(for="in_stock") В наличии:
            input#in_stock.form-checkbox(type="checkbox" name="in_stock" checked)
        .input-group
            label(for="image") Выберите изображение:
            input#image.form-input(type="file" name="image" accept="image/*")
        .action-buttons
            button.btn-primary(type="submit") Добавить продукт
            a.btn-secondary(href="/list-pitanie") Вернуться к списку